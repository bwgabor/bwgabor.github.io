<!DOCTYPE html>
<html lang="hu" data-bs-theme="light">

<head>
  <title>{{ title }}</title>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ description | default('Szibert Gábor IT rendszermérnök és DevOps portfóliója: Linux, automatizálás, CI/CD, Docker, monitoring, observability és dokumentációs projektek.') }}" />
  <link rel="canonical" href="https://bwgabor.github.io/">

  <meta name="google-site-verification" content="U5FadCEvyO8wjT_loMny51FcWQlAS7KLPt-C0CzivZU" />

  <!-- Open Graph / Social -->
  <meta property="og:type" content="website">
  <meta property="og:locale" content="hu_HU">
  <meta property="og:site_name" content="Sziebert Gábor">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description }}">
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:image" content="{{ ogImage }}">
  <meta property="og:image" content="https://bwgabor.github.io/assets/img/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Szibert Gábor - IT rendszermérnök és DevOps portfólió">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }}">
  <meta name="twitter:description" content="{{ description }}">
  <meta name="twitter:image" content="{{ ogImage }}">

  <!-- Bootstrap CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <!-- Styles -->
  {# <link rel="stylesheet" href="/css/bootstrap.min.css"> #}
  <link rel="stylesheet" href="/css/main.css">

  <script type="application/ld+json">
  {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "Sziebert Gábor",
    "alternateName": "Gábor Sziebert",
    "url": "https://bwgabor.github.io",
    "jobTitle": "IT rendszermérnök",
    "description": "IT rendszermérnök DevOps, infrastruktúra-automatizálás és observability fókusszal.",
    "sameAs": [
      "https://www.linkedin.com/in/gabor-sziebert/",
      "https://github.com/bwgabor"
    ],
    "image": {
      "@type": "ImageObject",
      "url": "https://bwgabor.github.io/assets/img/og-image.png",
      "width": 1200,
      "height": 630
    },
    "knowsAbout": [
      "Linux",
      "DevOps",
      "Infrastructure as Code",
      "CI/CD",
      "Docker",
      "Prometheus",
      "Grafana",
      "Loki",
      "Observability",
      "Virtualization",
      "Networking",
      "Technical Documentation",
      "AI-assisted workflows"
    ]
  }
}
  </script>

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-4W76F35N6G"></script>
  <script async src="/js/analytics.js"></script>

</head>

<body>

  <!-- NAVBAR -->
  <nav class="navbar navbar-expand-lg sticky-top site-nav" aria-label="Main navigation">
    <div class="container nav-inner">
      <a class="navbar-brand nav-logo" href="/#top"><h1>Gábor Sziebert</h1></a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="mainNav">
        <ul class="navbar-nav nav-links ms-auto mb-2 mb-md-0">
          {% for item in navigation %}
            <li class="nav-item">
              <a class="nav-link {% if page.url == item.url %}active{% endif %}" 
                href="{{ item.url }}"
                {% if item.external %}target="_blank" rel="noopener noreferrer"{% endif %}>
                {{ item.label }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </nav>

  

  {% block content %}{% endblock %}

  <footer class="site-footer py-4">
    <div class="container">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <p class="mb-0 footer-text">&copy; 2026 Sziebert Gábor</p>
        <div class="footer-links d-flex gap-3">
          {% for item in footer %}
            <a href="{{ item.url }}" {% if item.external %}target="_blank" rel="noopener noreferrer"{% endif %}>
              <i class="{{ item.icon }}"></i> {{ item.label }}
            </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </footer>

  <!-- Bootstrap JS Bundle -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js" defer></script>

</body>
</html>